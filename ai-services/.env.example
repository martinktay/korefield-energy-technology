# KoreField Academy AI Services — Environment Variables
# Copy to .env and fill in values

# Application
KF_ENVIRONMENT=dev
KF_DEBUG=true
KF_APP_VERSION=0.1.0

# CORS (comma-separated origins)
KF_CORS_ORIGINS=["http://localhost:3000"]

# LLM Provider
KF_OPENAI_API_KEY=sk-...
KF_DEFAULT_MODEL=gpt-4o

# LangSmith Observability
KF_LANGSMITH_API_KEY=lsv2_...
KF_LANGSMITH_PROJECT=korefield-academy
KF_LANGSMITH_TRACING_ENABLED=false

# RAG Configuration
KF_RAG_CHUNK_SIZE=1000
KF_RAG_CHUNK_OVERLAP=200
KF_RAG_EMBEDDING_MODEL=text-embedding-3-small
