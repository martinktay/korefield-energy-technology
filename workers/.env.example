# KoreField Academy — Workers Environment
DATABASE_URL=postgresql://korefield_admin:YOUR_PASSWORD@localhost:5432/korefield_academy?schema=public
NODE_ENV=development

# SQS Queue URLs
CERT_GENERATION_QUEUE_URL=
CERT_GENERATION_DLQ_URL=
AI_WORKFLOW_QUEUE_URL=
AI_WORKFLOW_DLQ_URL=
ANALYTICS_QUEUE_URL=
ANALYTICS_DLQ_URL=
NOTIFICATIONS_QUEUE_URL=
NOTIFICATIONS_DLQ_URL=
PAYMENT_EVENTS_QUEUE_URL=
PAYMENT_EVENTS_DLQ_URL=
EMAIL_QUEUE_URL=
EMAIL_DLQ_URL=

# AWS SES (email worker)
SES_SENDER_EMAIL=noreply@korefield.com
SES_AWS_REGION=eu-west-1
SES_MAX_SEND_RATE=14

# AI Services URL (ai-workflow worker)
AI_SERVICES_URL=http://localhost:8000

# S3 (cert-generation worker)
S3_CERTIFICATES_BUCKET=
AWS_REGION=eu-west-1
