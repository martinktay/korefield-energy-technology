{
  "name": "korefield-academy-workers",
  "version": "0.0.1",
  "description": "KoreField Academy Background Workers — SQS consumers",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "tsc",
    "start:cert-generation": "ts-node src/cert-generation.ts",
    "start:ai-workflow": "ts-node src/ai-workflow.ts",
    "start:analytics": "ts-node src/analytics.ts",
    "start:notifications": "ts-node src/notifications.ts",
    "start:payment-events": "ts-node src/payment-events.ts",
    "start:email-delivery": "ts-node src/email-delivery.ts",
    "lint": "eslint \"src/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.600.0",
    "@aws-sdk/client-secrets-manager": "^3.1019.0",
    "@aws-sdk/client-sesv2": "^3.1019.0",
    "@aws-sdk/client-sqs": "^3.600.0",
    "@prisma/client": "^5.15.0",
    "pdfkit": "^0.18.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.14.0",
    "@types/pdfkit": "^0.17.5",
    "fast-check": "^4.6.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
