# KoreField Academy Frontend — .dockerignore

# Dependencies (installed inside container)
node_modules/

# Build output (rebuilt inside container)
.next/
out/
dist/

# Environment files (injected at runtime)
.env
.env.local
.env.*.local

# Test artifacts
coverage/
playwright-report/
test-results/

# IDE / OS
.idea/
.vscode/
*.swp
.DS_Store

# Docs
*.md

# Logs
*.log
