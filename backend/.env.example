# KoreField Academy — Backend Environment
# Copy this file to .env and fill in your values.
#
# Database is hosted on AWS RDS PostgreSQL.
# Provision via: terraform apply -var-file=envs/dev.tfvars
# Retrieve credentials from AWS Secrets Manager after provisioning.

# AWS RDS PostgreSQL connection string
# db_name is "korefield" (set in Terraform rds module)
DATABASE_URL="postgresql://korefield_admin:YOUR_PASSWORD@your-rds-endpoint.eu-west-1.rds.amazonaws.com:5432/korefield_academy?schema=public&sslmode=require"

# Backend server port (3001 to avoid conflict with Next.js on 3000)
PORT=3001

# Environment: development | staging | production
NODE_ENV=development

# JWT signing secret — use AWS Secrets Manager in staging/production
JWT_SECRET=your-jwt-secret-here

# JWT token expiration in seconds (3600 = 1 hour)
JWT_EXPIRATION_SECONDS=3600

# HMAC-SHA256 secret for payment webhook signature verification
PAYMENT_WEBHOOK_SECRET=your-webhook-secret-here

# Email System (AWS SES + SQS)
SES_SENDER_EMAIL=noreply@korefield.com
SES_AWS_REGION=eu-west-1
SES_MAX_SEND_RATE=14
EMAIL_QUEUE_URL=
EMAIL_DLQ_URL=
FRONTEND_URL=http://localhost:3000
